@code 
{
    private LawRoot[]? laws;
    public required string a;
    public required int b;
    string? c, d, e, f, g, h;
    int h1c, h2c, h3c, h4c, h5c, h6c, pc, subpc, itemc, ofc;
    string[] h1 = [], h2 = [], h3 = [], h4 = [], h5 = [], h6 = [];
    string[] lip = [], lisubp = [], liitem = [], liof = [];
    int aCount, ic, iex, il, ij, iel;
    L[] lc = [], lex = [], ll = [], lj = [], lel = [];
    private A[] artarray = []; 
    private A art;
    int aa = -1 ; 
    protected override void OnInitialized()
    {
        var uri = N.ToAbsoluteUri(N.Uri);
        var queryStrings = QueryHelpers.ParseQuery(uri.Query);
        if (queryStrings.TryGetValue("a", out var aaa))
        {
            a = aaa!;
        }
        if (queryStrings.TryGetValue("p", out var bbb))
        {
            b = ( bbb == "" || bbb == (string?)null ) ? -1 : ( int.Parse( bbb! ) - 1 ) ; 
        }
        if (queryStrings.TryGetValue("from", out var ccc))
        {
            c = ccc ; 
        }
        if (queryStrings.TryGetValue("q", out var ddd))
        {
            d = ddd ; 
        }
        if (queryStrings.TryGetValue("c", out var eee))
        {
            e = eee ; 
        }
        if (queryStrings.TryGetValue("f", out var fff))
        {
            f = fff ; 
        }
        if (queryStrings.TryGetValue("l", out var ggg))
        {
            g = ggg ; 
        }
        if (queryStrings.TryGetValue("ab", out var hhh))
        {
            h = hhh ; 
        }
        aa = string.IsNullOrEmpty(a) ? -1 : int.Parse( Regex.Replace( a.ToUpper() , @"[CXLJE]"  , "" ) ) - 1 ; 
    }

    protected override async Task OnInitializedAsync()
    {
        if( aa != -1 && b >= 0 ) 
        {
            laws = await Http.GetFromJsonAsync<LawRoot[]>("json/laws.json");
            lel = laws![0].Laws.Where(l => l.LawCategory.Contains("選舉法規")).ToArray();
            iel = lel.Length;
            lc = laws![0].Laws.Where(l => !l.LawCategory.Contains("選舉法規") && l.LawCategory.Contains("中央法規")).ToArray();
            ic = lc.Length;
            lex = laws![0].Laws.Where(l => !l.LawCategory.Contains("選舉法規") && l.LawCategory.Contains("行政法規")).ToArray();
            iex = lex.Length;
            ll = laws![0].Laws.Where(l => !l.LawCategory.Contains("選舉法規") && l.LawCategory.Contains("立法法規")).ToArray();
            il = lel.Length;
            lj = laws![0].Laws.Where(l => !l.LawCategory.Contains("選舉法規") && l.LawCategory.Contains("司法法規")).ToArray();
            ij = lj.Length;
            switch (a.ToUpper()[0])
            {
                case 'C':
                {
                    artarray = lc[aa].LawArticles.Where(x => x.ArticleType == "A").ToArray();
                    aCount = artarray.Length;
                    art = artarray[b] ;
                    break;
                }
                case 'X':
                {
                    artarray = lex[aa].LawArticles.Where(x => x.ArticleType == "A").ToArray();
                    aCount = artarray.Length;
                    art = artarray[b] ;
                    break;
                }
                case 'L':
                {
                    artarray = ll[aa].LawArticles.Where(x => x.ArticleType == "A").ToArray();
                    aCount = artarray.Length;
                    art = artarray[b] ;
                    break;
                }
                case 'J':
                {
                    artarray = lj[aa].LawArticles.Where(x => x.ArticleType == "A").ToArray();
                    aCount = artarray.Length;
                    art = artarray[b] ;
                    break;
                }
                case 'E':
                {
                    artarray = lel[aa].LawArticles.Where(x => x.ArticleType == "A").ToArray();
                    aCount = artarray.Length;
                    art = artarray[b] ;
                    break;
                }
            }
            if( a.ToUpper()[0] == 'C' ) 
            {
                foreach( var l in lc[aa].LawArticles ) 
                {
                    if (l.ArticleType == "C")
                    {
                        if (l.ArticleContent[0] == '第') @*編*@
                        {
                            h1c++;
                        }
                        else if (l.ArticleContent[3] == '第') @*章*@
                        {
                            h2c++;
                        }
                        else if (l.ArticleContent[6] == '第') @*節*@
                        {
                            h3c++;
                        }
                        else if (l.ArticleContent[9] == '第') @*款*@
                        {
                            h4c++;
                        }
                        else if (l.ArticleContent[12] == '第') @*目*@
                        {
                            h5c++;
                        }
                    }
                    else if( l.ArticleType == "A" ) 
                    {
                        h6c ++ ; 
                        foreach( var p in l.ArticleContent.Split( "\r\n" ) ) 
                        {
                            if( Regex.IsMatch( p , @"^([1-9]{1}[0-9]+、|[1-9]{1}、|[１-９]{1}[０-９]+、|[１-９]{1}、|[1-9]{1}[0-9]+\u002E|[1-9]{1}\u002E)" ) ) 
                            {
                                ofc ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^(（[一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+）|（[一二三四五六七八九十]{1}）|（[1-9]{1}[0-9]+）|（[1-9]{1}）|（[１-９]{1}[０-９]+）|（[１-９]{1}）)"))
                            {
                                itemc ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^([一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+、|[一二三四五六七八九十]{1}、)"))
                            {
                                subpc ++ ; 
                            }
                            else 
                            {
                                pc ++ ; 
                            }
                        }
                    }
                }
            }
            else if( a.ToUpper()[0] == 'X' ) 
            {
                foreach( var l in lex[aa].LawArticles ) 
                {
                    if (l.ArticleType == "C")
                    {
                        if (l.ArticleContent[0] == '第') @*編*@
                        {
                            h1c++;
                        }
                        else if (l.ArticleContent[3] == '第') @*章*@
                        {
                            h2c++;
                        }
                        else if (l.ArticleContent[6] == '第') @*節*@
                        {
                            h3c++;
                        }
                        else if (l.ArticleContent[9] == '第') @*款*@
                        {
                            h4c++;
                        }
                        else if (l.ArticleContent[12] == '第') @*目*@
                        {
                            h5c++;
                        }
                    }
                    else if( l.ArticleType == "A" ) 
                    {
                        h6c ++ ; 
                        foreach( var p in l.ArticleContent.Split( "\r\n" ) ) 
                        {
                            if( Regex.IsMatch( p , @"^([1-9]{1}[0-9]+、|[1-9]{1}、|[１-９]{1}[０-９]+、|[１-９]{1}、|[1-9]{1}[0-9]+\u002E|[1-9]{1}\u002E)" ) ) 
                            {
                                ofc ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^(（[一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+）|（[一二三四五六七八九十]{1}）|（[1-9]{1}[0-9]+）|（[1-9]{1}）|（[１-９]{1}[０-９]+）|（[１-９]{1}）)"))
                            {
                                itemc ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^([一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+、|[一二三四五六七八九十]{1}、)"))
                            {
                                subpc ++ ; 
                            }
                            else 
                            {
                                pc ++ ; 
                            }
                        }
                    }
                }
            }
            else if( a.ToUpper()[0] == 'L' ) 
            {
                foreach( var l in ll[aa].LawArticles ) 
                {
                    if (l.ArticleType == "C")
                    {
                        if (l.ArticleContent[0] == '第') @*編*@
                        {
                            h1c++;
                        }
                        else if (l.ArticleContent[3] == '第') @*章*@
                        {
                            h2c++;
                        }
                        else if (l.ArticleContent[6] == '第') @*節*@
                        {
                            h3c++;
                        }
