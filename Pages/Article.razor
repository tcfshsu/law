                            h4[idh4] = iiih1 + "_" + iiih2 + "__" + iiih3 + "___" + l.ArticleContent.Replace( " " , "" ) ; 
                            idh4 ++ ; 
                            iiih5 = 0 ; 
                        }
                        else if (l.ArticleContent[12] == '第') @*目*@
                        {
                            iiih5 ++ ; 
                            h5[idh5] = iiih1 + "_" + iiih2 + "__" + iiih3 + "___" + iiih4 + "____" + l.ArticleContent.Replace( " " , "" ) ; 
                            idh5 ++ ; 
                        }
                    }
                    else if( l.ArticleType == "A" ) 
                    {
                        h6[idh6] = l.ArticleNo ; 
                        int iiip = 0 ; 
                        int iiisubp = 0 ; 
                        int iiiitem = 0 ; 
                        int iiiof = 0 ; 
                        foreach( var p in l.ArticleContent.Split( "\r\n" ) ) 
                        {
                            if( Regex.IsMatch( p , @"^([1-9]{1}[0-9]+、|[1-9]{1}、|[１-９]{1}[０-９]+、|[１-９]{1}、|[1-9]{1}[0-9]+\u002E|[1-9]{1}\u002E)" ) ) 
                            {
                                iiiof ++ ; 
                                liof[idof] = l.ArticleNo + "_" + iiip + "__" + iiisubp + "___" + iiiitem + "____" + iiiof ; 
                                idof ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^(（[一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+）|（[一二三四五六七八九十]{1}）|（[1-9]{1}[0-9]+）|（[1-9]{1}）|（[１-９]{1}[０-９]+）|（[１-９]{1}）)"))
                            {
                                iiiitem ++ ; 
                                liitem[iditem] = l.ArticleNo + "_" + iiip + "__" + iiisubp + "___" + iiiitem ; 
                                iditem ++ ; 
                            }
                            else if (Regex.IsMatch(p, @"^([一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+、|[一二三四五六七八九十]{1}、)"))
                            {
                                iiisubp ++ ; 
                                lisubp[idsubp] = l.ArticleNo + "_" + iiip + "__" + iiisubp ; 
                                idsubp ++ ; 
                            }
                            else 
                            {
                                iiip ++ ; 
                                lip[idp] = l.ArticleNo + "_" + iiip ; 
                                iiiof = 0 ; 
                                iiiitem = 0 ; 
                                iiisubp = 0 ; 
                                idp ++ ; 
                            }
                        }
                        idh6 ++ ; 
                    }
                }
            }
        }
    }

