@page "/s"
@inject HttpClient Http
<PageTitle>統計 - 臺中市立臺中第一高級中等學校學生自治聯合會法規資料庫</PageTitle>

<style>
    .statistics_table 
    {
        border : 1px #000 solid ; 
    }
    .statistics_table tr 
    {
        border-bottom : 1px #000 solid ; 
    }
    .statistics_table th , .statistics_table td 
    {
        border-right : 1px #000 solid ; 
    }
</style>

<div class="bread">
    <span>現在位置：</span>
    <ul>
        <li><a href="">首頁</a></li>
        <li>統計</li>
    </ul>
</div>

<h1>統計</h1>
<h3>法規</h3>
<table class="statistics_table">
    <thead style="font-family:'IBM Plex Mono', 'Sonti TC' , '標點' , 'Noto Serif KR' , 'Noto Serif TC' , 'Noto Serif JP' , 'Noto Serif SC' , sans-serif;">
        <tr>
            <th>字</th>
            <th>unicode</th>
            <th>出現次數</th>
            <th>占比( ‰ )</th>
        </tr>
    </thead>
    <tbody style="font-family:'Fira Code', 'Sonti TC' , '標點' , 'Noto Serif KR' , 'Noto Serif TC' , 'Noto Serif JP' , 'Noto Serif SC' , sans-serif;">
        @if(r.Count > 0)
        {
            @foreach (var x in r.OrderByDescending(x => x.C).ThenBy(x => x.A))
            {
                int xa = x.A;
                decimal xc = x.C * 1000;
                
                <tr>
                    <td>@x.A</td>
                    <td style="min-width:calc(6em + 2px);">@("U+" + xa.ToString("X4"))</td>
                    <td>@x.C</td>
                    <td>@(xc / wc)</td>
                </tr>
            }
        }
        else 
        {
            <span>Loading...</span>
        }
    </tbody>
</table>
<br />
<br />
<h3>判例</h3>
<table class="statistics_table">
    <thead style="font-family:'IBM Plex Mono', 'Sonti TC' , '標點' , 'Noto Serif KR' , 'Noto Serif TC' , 'Noto Serif JP' , 'Noto Serif SC' , sans-serif;">
        <tr>
            <th>字</th>
            <th>unicode</th>
            <th>出現次數</th>
        </tr>
    </thead>
    <tbody style="font-family:'Fira Code', 'Sonti TC' , '標點' , 'Noto Serif KR' , 'Noto Serif TC' , 'Noto Serif JP' , 'Noto Serif SC' , sans-serif;">
        @if(rc.Count > 0)
        {
            @foreach (var x in rc.OrderByDescending(x => x.C).ThenBy(x => x.A))
            {
                int xa = x.A;

                <tr>
                    <td>@x.A</td>
                    <td style="min-width:calc(6em + 2px);">@("U+" + xa.ToString("X4"))</td>
                    <td>@x.C</td>
                </tr>
            }
        }
        else 
        {
            <span>Loading...</span>
        }
    </tbody>
</table>

@code 
{
    public class Result(char a, int c)
    {
        public char A { get; init; } = a;
        public int C { get; init; } = c;
    }
    List<Result> r = [];
    List<Result> rc = [];
    int wc;
    string ljson = "", cjson = "";
    protected override async Task OnInitializedAsync()
    {
        ljson = await Http.GetStringAsync("json/laws.json");
        cjson = await Http.GetStringAsync("json/cases.json");
        ljson = Regex.Replace(ljson, @"[!-⬍⿰-㏿ﬓ-�\s]", "");
        cjson = Regex.Replace(cjson, @"[!-⬍⿰-㏿ﬓ-�\s]", "");
        for (int i = 0; i < ljson.Length; ++i)
        {
            int ii = ljson.Count(j => j == ljson[0]);
            r.Add(new(ljson[0], ii));
            ljson = ljson.Replace(ljson[0].ToString(), "");
            if (ljson == string.Empty)
            {
                break;
            }
        }
        foreach (var x in r)
        {
            wc += x.C;
        }
        for (int i = 0; i < cjson.Length; ++i)
        {
            int ii = cjson.Where(j => j == cjson[0]).ToArray().Length;
            rc.Add(new(cjson[0], ii));
            cjson = cjson.Replace(cjson[0].ToString(), "");
            if (cjson == string.Empty)
            {
                break;
            }
        }
    }
}