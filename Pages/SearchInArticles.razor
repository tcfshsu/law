@* @page "/laws/s"  *@
@inject HttpClient Http 
@inject NavigationManager N 

<div class="bread">
    <span>現在位置：</span>
    <ul>
        <li><a href="">首頁</a></li>
        <li><a href="laws">法規查詢</a></li>
        <li></li>
    </ul>
</div>

<br class="printNoDisplay" />
<a class="printNoDisplay" href="@( string.IsNullOrEmpty( d ) ? $"laws?q={b}&c={c}&l={e}&ab={f}" : ( Regex.IsMatch( d.ToUpper() , "^(L{1}N{1})" ) ? $"latest?no={d.ToUpper().Replace( "LN" , "" )}" : $"laws?q={b}&c={c}" ) )">回上頁</a>

@code 
{
    LawRoot[]? laws ;
    string? a, b, c, d, e, f, g, h;
    int aa = 0;
    // int[]? artNo;
    L? l;
    List<A> aq = [];
    protected override void OnInitialized()
    {
        var uri = N.ToAbsoluteUri(N.Uri);
        var queryStrings = QueryHelpers.ParseQuery(uri.Query);
        if (queryStrings.TryGetValue("a", out var aaa))
        {
            a = aaa!;
        }
        if (queryStrings.TryGetValue("q", out var bbb))
        {
            b = bbb;
        }
        if (queryStrings.TryGetValue("c", out var ccc))
        {
            c = ccc;
        }
        if (queryStrings.TryGetValue("f", out var ddd))
        {
            d = ddd;
        }
        if (queryStrings.TryGetValue("l", out var eee))
        {
            e = eee;
        }
        if (queryStrings.TryGetValue("ab", out var fff))
        {
            f = fff;
        }
        if (queryStrings.TryGetValue("v", out var ggg))
        {
            g = ggg;
        }
        if (queryStrings.TryGetValue("string", out var hhh))
        {
            h = hhh;
        }
        aa = string.IsNullOrEmpty(a) ? -1 : int.Parse( Regex.Replace( a.ToUpper() , "[CXLJE]"  , "" ) ) - 1 ; 
    }
    protected override async Task OnInitializedAsync()
    {
        laws = await Http.GetFromJsonAsync<LawRoot[]>("json/laws.json");
        if( laws != null ) 
        {
            l = laws[0].Laws.Where( x => !string.IsNullOrEmpty( a ) && ( Regex.Replace( a.ToUpper() , "[^CXLJE]"  , "" ).ToUpper() == "E" ? x.LawCategory.Contains( "選舉法規" ) : Regex.Replace( a.ToUpper() , "[^CXLJE]"  , "" ).ToUpper() == "C" ? !x.LawCategory.Contains( "選舉法規" ) && x.LawCategory.Contains( "中央法規" ) : Regex.Replace( a.ToUpper() , "[^CXLJE]"  , "" ).ToUpper() == "X" ? !x.LawCategory.Contains( "選舉法規" ) && x.LawCategory.Contains( "行政法規" ) : Regex.Replace( a.ToUpper() , "[^CXLJE]"  , "" ).ToUpper() == "L" ? !x.LawCategory.Contains( "選舉法規" ) && x.LawCategory.Contains( "立法法規" ) : Regex.Replace( a.ToUpper() , "[^CXLJE]"  , "" ).ToUpper() == "J" && !x.LawCategory.Contains( "選舉法規" ) && x.LawCategory.Contains( "司法法規" ) ) ).ToArray()[aa] ; 
        }
    }

    public class LawRoot
    {
        public required L[] Laws { get; set; }
    }
    public class L
    {
        public required string LawCategory { get; set; }
        public required string LawForeword { get; set; }
        public required A[] LawArticles { get; set; }
        public bool Contains( string a ) 
        {
            if( !string.IsNullOrEmpty( LawForeword ) && LawForeword.ToUpper().Contains( a ) ) 
            {
                return true ; 
            }
            return LawArticles.Any(art => art.ArticleType.ToUpper().Contains(a) || (!string.IsNullOrEmpty(art.ArticleNo) && art.ArticleNo.ToUpper().Contains(a)) || art.ArticleContent.ToUpper().Contains(a));
        }
    }
    public class A
    {
        public required string ArticleType { get; set; }
        public required string ArticleNo { get; set; }
        public required string ArticleContent { get; set; }
        public string ShowNum() 
        {
            return ArticleContent.Split("\r\n").Count(a => !Regex.IsMatch(a, @"^([1-9]{1}[0-9]+、|[1-9]{1}、|[１-９]{1}[０-９]+、|[１-９]{1}、|[1-9]{1}[0-9]+\u002E|[1-9]{1}\u002E|[１-９]{1}[０-９]+\u002E|[１-９]{1}\u002E|（[一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+）|（[一二三四五六七八九十]{1}）|（[1-9]{1}[0-9]+）|（[1-9]{1}）|（[１-９]{1}[０-９]+）|（[１-９]{1}）|[一二三四五六七八九十]{1}[一二三四五六七八九○零十百]+、|[一二三四五六七八九十]{1}、)")) > 1 ? "showNum" : "" ; 
        }
        public bool Contains( string a ) 
        {
            if( Regex.IsMatch( a , @"([(].+[)])|[+\-&]" ) ) 
            {}
            else if( Regex.IsMatch( a , @"\s" ) ) 
            {
                foreach( var aa in Regex.Split( a , @"\s" ) ) 
                {
                    if( !string.IsNullOrEmpty( ArticleNo ) && ArticleNo.Contains( "【" ) && ArticleNo.Split( "【" )[1].Replace( "】" , "" ).ToUpper().Contains( aa ) ) 
                    {
                        return true ; 
                    }
                    if( ArticleContent.ToUpper().Contains( aa ) ) 
                    {
                        return true ; 
                    }
                }
            }
            else 
            {
                return ArticleContent.ToUpper().Contains( a ) || ( !string.IsNullOrEmpty( ArticleNo ) && ArticleNo.Contains( "【" ) && ArticleNo.Split( "【" )[1].Replace( "】" , "" ).ToUpper().Contains( a ) ) ; 
            }
            return false ; 
        }
    }
}